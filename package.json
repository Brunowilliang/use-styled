{
  "name": "use-styled",
  "version": "0.1.12",
  "description": "A lightweight styled components library optimized for Tailwind CSS.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "yarn build",
    "check:size": "bundlewatch --config bundlewatch.config.js"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": ">=18.0.0",
    "bundlewatch": "^0.4.1",
    "tslib": "^2.8.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "react",
    "react-native",
    "styled",
    "tailwind",
    "css-in-js",
    "utility",
    "hook"
  ],
  "author": "Bruno Garcia <eu@brunowillian.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Brunowilliang/use-styled.git"
  },
  "homepage": "https://github.com/Brunowilliang/use-styled",
  "bugs": {
    "url": "https://github.com/Brunowilliang/use-styled/discussions"
  }
}
